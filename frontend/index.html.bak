  </div>
  <div class="tbl-wrap">
    <table><thead><tr><th>Department</th><th>Avg GPA</th><th>Avg Attendance</th><th>At-Risk</th><th>Pass Rate</th><th>Trend</th></tr></thead>
    <tbody>
      ${analyticsRow('Computer Science','3.52','83%','12','97%','↑')}
      ${analyticsRow('Mathematics','3.40','79%','18','95%','→')}
