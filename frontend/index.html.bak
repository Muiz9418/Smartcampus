const GRADE_DATA = [
  {id:'2021/CS/001',name:'Amaka Obi',ca:35,exam:null},
  {id:'2021/CS/002',name:'Bode Lawal',ca:22,exam:null},
  {id:'2021/CS/003',name:'Chisom Eze',ca:38,exam:null},
  {id:'2021/CS/004',name:'Dayo Femi',ca:28,exam:null},
  {id:'2021/CS/005',name:'Efe Igho',ca:19,exam:null},
  {id:'2021/CS/006',name:'Funke Adeyemi',ca:36,exam:null},
];

function gradeCalc(ca,exam){
  if(ca===null||exam===null) return {total:'—',grade:'—'};
  const t=ca+exam;
  const g=t>=70?'A':t>=60?'B':t>=50?'C':t>=45?'D':'F';
  return {total:t,grade:g};
}

function lecturerUploadGrades(){
  const rows=GRADE_DATA.map((s,i)=>{
    const r=gradeCalc(s.ca,s.exam);
    return `<tr>
      <td><span style="font-family:var(--mono);font-size:12px">${s.id}</span></td>
      <td class="font-medium">${s.name}</td>
      <td><input class="grade-input" type="number" min="0" max="40" value="${s.ca}" id="ca-${i}" oninput="updateGrade(${i},'ca',this.value)"/></td>
      <td><input class="grade-input" type="number" min="0" max="60" placeholder="—" id="ex-${i}" oninput="updateGrade(${i},'ex',this.value)"/></td>
      <td><span id="total-${i}" style="font-family:var(--mono);font-weight:500">${r.total}</span></td>
      <td><span id="grade-${i}" class="badge ${r.grade==='A'?'badge-green':r.grade==='B'?'badge-blue':r.grade==='C'?'badge-amber':'badge-gray'}">${r.grade}</span></td>
    </tr>`;
  }).join('');
  return `
  <div class="page-header">
    <div><div class="page-title">Upload Grades</div><div class="page-subtitle">CSC 301 — Algorithms · 2024/25 Semester 1</div></div>
    <div class="flex gap-2">
      <button class="btn btn-outline">${iconDown()} Import CSV Template</button>
      <button class="btn btn-primary" onclick="submitGrades()">Submit Grades</button>
    </div>
  </div>
  <div class="card" style="margin-bottom:16px">
    <div class="grid-3">
      <div><div class="text-xs text-faint uppercase" style="letter-spacing:.05em">Course</div><div class="font-medium" style="margin-top:2px">CSC 301 — Algorithms</div></div>
      <div><div class="text-xs text-faint uppercase" style="letter-spacing:.05em">CA Weight</div><div class="font-medium" style="margin-top:2px">40 marks</div></div>
      <div><div class="text-xs text-faint uppercase" style="letter-spacing:.05em">Exam Weight</div><div class="font-medium" style="margin-top:2px">60 marks</div></div>
    </div>
  </div>
  <div class="tbl-wrap">
    <table><thead><tr><th>Matric</th><th>Student</th><th>CA /40</th><th>Exam /60</th><th>Total /100</th><th>Grade</th></tr></thead>
    <tbody>${rows}</tbody></table>
  </div>
  <div class="flex gap-2" style="margin-top:16px">
    <button class="btn btn-primary" onclick="submitGrades()">Submit Grades</button>
    <button class="btn btn-outline">Save Draft</button>
  </div>`;
}

function updateGrade(i,field,val){
  if(field==='ca') GRADE_DATA[i].ca=Number(val);
  else GRADE_DATA[i].exam=Number(val);
  const r=gradeCalc(GRADE_DATA[i].ca, GRADE_DATA[i].exam===null?null:GRADE_DATA[i].exam);
  const tEl=document.getElementById(`total-${i}`);
  const gEl=document.getElementById(`grade-${i}`);
  if(tEl) tEl.textContent=r.total;
  if(gEl){
    gEl.textContent=r.grade;
    gEl.className=`badge ${r.grade==='A'?'badge-green':r.grade==='B'?'badge-blue':r.grade==='C'?'badge-amber':'badge-gray'}`;
  }
}
function submitGrades(){alert('Grades submitted successfully! The registry has been notified.');}

function lecturerNotifications(){
  const items=[
    {unread:true,icon:'📢',title:'Grade Submission Deadline — Apr 1',desc:'Grades for CSC 301 and CSC 401 must be submitted by April 1, 2026.',time:'Today',tag:'Admin'},
    {unread:true,icon:'📋',title:'Faculty Meeting — Wednesday 4pm',desc:'All teaching staff are expected at the faculty board meeting in Room 101.',time:'Today',tag:'Meeting'},
    {unread:false,icon:'📣',title:'Exam Timetable Released',desc:'The final examination timetable for 2024/25 Semester 1 has been published.',time:'Yesterday',tag:'Exams'},
    {unread:false,icon:'⚠️',title:'2 Students At-Risk in CSC 301',desc:'Students Bode Lawal and Efe Igho are below the 70% attendance threshold.',time:'2 days ago',tag:'Attendance'},
  ];
  return `
  <div class="page-header">
    <div><div class="page-title">Notifications</div><div class="page-subtitle">${items.filter(i=>i.unread).length} unread</div></div>
    <button class="btn btn-ghost btn-sm">Mark all as read</button>
  </div>
  <div class="card">
    ${items.map(n=>`<div class="notif-item"><div class="notif-dot-icon ${n.unread?'':'read'}"></div><div class="notif-body"><div class="flex justify-between items-start"><div class="notif-title">${n.icon} ${n.title}</div><span class="badge badge-gray text-xs" style="margin-left:8px;flex-shrink:0">${n.tag}</span></div><div class="notif-desc">${n.desc}</div><div class="notif-time">${n.time}</div></div></div>`).join('')}
  </div>`;
}

