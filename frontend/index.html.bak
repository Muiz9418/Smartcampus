<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>SmartCampus</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,400&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet"/>
<link rel="stylesheet" href="styles.css"/>
</head>
<body>

<!-- ═══════════════════════════════════════════════════════════════════ -->
<!--  LOGIN PAGE                                                         -->
<!-- ═══════════════════════════════════════════════════════════════════ -->
<div id="login-page">
  <div class="login-box">
    <div class="login-logo">
      <div class="login-logo-mark">SC</div>
      <div class="login-title">SmartCampus</div>
      <div class="login-sub">University Management System</div>
    </div>

    <!-- LOGIN CARD -->
    <div class="login-card" id="login-card">
      <div class="login-card-header">
        <h2 class="login-card-title">Welcome back</h2>
        <p class="login-card-desc">Sign in with your matric number or staff ID</p>
      </div>
      <div class="login-form">
        <div class="login-field">
          <label class="login-label">Matric / Staff ID</label>
          <input class="login-form-input" type="text" id="login-identifier"
            placeholder="e.g. 2021/CS/042 or STF-0041"/>
        </div>
        <div class="login-field">
          <label class="login-label">Password</label>
          <div class="login-input-wrap">
            <input class="login-form-input" type="password" id="login-password" placeholder="Enter your password"/>
            <span class="login-eye" onclick="togglePwd('login-password',this)">👁</span>
          </div>
        </div>
        <div class="login-error hidden" id="login-error"></div>
        <button class="login-btn" id="login-btn" onclick="doLogin()">
          <span id="login-btn-text">Sign in</span>
        </button>
      </div>
      <div class="login-switch">
        Don't have an account?
        <span class="login-switch-link" onclick="showSignup()">Create one</span>
      </div>
      <div class="login-demo-creds">
        <div class="login-demo-title">Demo credentials</div>
        <div class="login-demo-row" onclick="fillLogin('2021/CS/0042','password')">
          <span class="login-demo-badge student">Student</span>
          <span class="login-demo-id">2021/CS/0042</span>
          <span class="login-demo-pw">password</span>
        </div>
        <div class="login-demo-row" onclick="fillLogin('STF-0041','password')">
          <span class="login-demo-badge lecturer">Lecturer</span>
          <span class="login-demo-id">STF-0041</span>
          <span class="login-demo-pw">password</span>
        </div>
        <div class="login-demo-row" onclick="fillLogin('ADM-001','password')">
          <span class="login-demo-badge admin">Admin</span>
          <span class="login-demo-id">ADM-001</span>
          <span class="login-demo-pw">password</span>
        </div>
      </div>
    </div>

    <!-- SIGNUP CARD -->
    <div class="login-card hidden" id="signup-card">
      <div class="login-card-header">
        <h2 class="login-card-title">Create account</h2>
        <p class="login-card-desc">Use your matric number or staff ID to register</p>
      </div>
      <div class="login-form">
        <div class="login-field">
          <label class="login-label">Matric / Staff ID</label>
          <input class="login-form-input" type="text" id="su-identifier"
            placeholder="e.g. 2021/CS/042 or STF-0041" oninput="detectRoleHint(this.value)"/>
          <div class="login-role-hint hidden" id="su-role-hint"></div>
        </div>
        <div class="login-field">
          <label class="login-label">Full Name</label>
          <input class="login-form-input" type="text" id="su-name" placeholder="e.g. Muiz Adeyemi"/>
        </div>
        <div class="login-field">
          <label class="login-label">University Email</label>
          <input class="login-form-input" type="email" id="su-email" placeholder="you@unilag.edu.ng"/>
        </div>
        <div class="login-field">
          <label class="login-label">Department</label>
          <input class="login-form-input" type="text" id="su-dept" placeholder="e.g. Computer Science"/>
        </div>
        <div class="login-field">
          <label class="login-label">Password</label>
          <div class="login-input-wrap">
            <input class="login-form-input" type="password" id="su-password" placeholder="Min. 6 characters"/>
            <span class="login-eye" onclick="togglePwd('su-password',this)">👁</span>
          </div>
        </div>
        <div class="login-error hidden" id="signup-error"></div>
        <button class="login-btn" onclick="doSignup()">
          <span id="signup-btn-text">Create account</span>
        </button>
      </div>
      <div class="login-switch">
        Already have an account?
        <span class="login-switch-link" onclick="showLogin()">Sign in</span>
      </div>
    </div>

  </div>
</div>

<!-- ═══════════════════════════════════════════════════════════════════ -->
<!--  APP SHELL                                                          -->
<!-- ═══════════════════════════════════════════════════════════════════ -->
<div id="app" class="hidden">
  <!-- SIDEBAR -->
  <aside class="sidebar" id="sidebar">
    <div class="sidebar-header">
      <div class="sidebar-logo" id="sb-logo">SC</div>
      <div>
        <div class="sidebar-app-name">SmartCampus</div>
        <div class="sidebar-role-badge" id="sb-role-badge">Student</div>
      </div>
    </div>
    <nav class="sidebar-nav" id="sidebar-nav"></nav>
    <div class="sidebar-footer">
      <div class="user-row">
        <div class="user-avatar" id="sb-avatar">OA</div>
        <div>
          <div class="user-name" id="sb-user-name">Obi Ade</div>
          <div class="user-role" id="sb-user-role">300L · Computer Science</div>
        </div>
      </div>
      <button class="logout-btn" onclick="doLogout()">← Sign out</button>
    </div>
  </aside>

  <!-- MAIN -->
  <div class="main">
    <header class="topbar">
      <div class="topbar-title" id="topbar-title">Dashboard</div>
      <div class="topbar-actions">
        <div class="icon-btn notif-dot" onclick="navigate('notifications')" title="Notifications">
          <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
        </div>
        <div class="icon-btn" onclick="navigate('profile')" title="Profile">
          <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><circle cx="12" cy="8" r="4"/><path d="M20 21a8 8 0 1 0-16 0"/></svg>
        </div>
      </div>
    </header>
    <main class="page-content" id="page-content"></main>
  </div>
</div>

<script>
// ═══════════════════════════════════════════════════════════════════════
//  STATE
// ═══════════════════════════════════════════════════════════════════════
let currentRole = 'student';
let currentPage = 'dashboard';

const USERS = {
  student:  { name:'Obi Ade',        initials:'OA', sub:'300L · Computer Science',  email:'student@unilag.edu.ng' },
  lecturer: { name:'Dr. David Eze',   initials:'DE', sub:'Dept. of Computer Science', email:'deze@unilag.edu.ng' },
  admin:    { name:'Fatima Aliyu',    initials:'FA', sub:'Registry · Administration',  email:'faliyu@unilag.edu.ng' },
};

const NAV_CONFIG = {
  student: [
    { section:'Overview', items:[
      { id:'dashboard',     label:'Dashboard',          icon:iconHome },
      { id:'notifications', label:'Notifications',      icon:iconBell },
    ]},
    { section:'Academics', items:[
      { id:'courses',       label:'Courses & Timetable', icon:iconCalendar },
      { id:'attendance',    label:'My Attendance',       icon:iconCheck },
      { id:'grades',        label:'Grades & Results',    icon:iconStar },
      { id:'transcript',    label:'Transcript',          icon:iconFile },
    ]},
    { section:'Account', items:[
      { id:'profile',       label:'Profile & Settings',  icon:iconUser },
    ]},
  ],
  lecturer: [
    { section:'Overview', items:[
      { id:'dashboard',     label:'Dashboard',           icon:iconHome },
      { id:'notifications', label:'Notifications',       icon:iconBell },
    ]},
    { section:'Teaching', items:[
      { id:'schedule',      label:'My Schedule',         icon:iconCalendar },
      { id:'mark-att',      label:'Mark Attendance',     icon:iconCheck },
      { id:'att-reports',   label:'Attendance Reports',  icon:iconBarChart },
      { id:'upload-grades', label:'Upload Grades',       icon:iconUpload },
    ]},
    { section:'Account', items:[
      { id:'profile',       label:'Profile & Settings',  icon:iconUser },
    ]},
  ],
  admin: [
    { section:'Overview', items:[
      { id:'dashboard',     label:'Admin Dashboard',     icon:iconHome },
      { id:'analytics',     label:'Reports & Analytics', icon:iconBarChart },
    ]},
    { section:'People', items:[
      { id:'students',      label:'Manage Students',     icon:iconUsers },
      { id:'lecturers',     label:'Manage Lecturers',    icon:iconUsers },
    ]},
    { section:'Academics', items:[
      { id:'courses',       label:'Course Management',   icon:iconBook },
      { id:'timetable',     label:'Timetable Mgmt.',     icon:iconCalendar },
      { id:'att-overview',  label:'Attendance Overview', icon:iconCheck },
      { id:'grades-mgmt',   label:'Grades Management',   icon:iconStar },
    ]},
    { section:'System', items:[
      { id:'broadcast',     label:'Broadcast Notif.',    icon:iconBell },
      { id:'settings',      label:'System Settings',     icon:iconSettings },
    ]},
  ],
};

// ═══════════════════════════════════════════════════════════════════════
//  SVG ICONS
// ═══════════════════════════════════════════════════════════════════════
function icon(d,extra=''){return`<svg class="nav-icon" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24" ${extra}>${d}</svg>`}
function iconHome(){return icon('<rect x="3" y="11" width="18" height="10" rx="2"/><path d="M3 11L12 3l9 8"/>')}
function iconBell(){return icon('<path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/>')}
function iconCalendar(){return icon('<rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/>')}
function iconCheck(){return icon('<path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="M22 4L12 14.01l-3-3"/>')}
function iconStar(){return icon('<polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>')}
function iconFile(){return icon('<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/>')}
function iconUser(){return icon('<circle cx="12" cy="8" r="4"/><path d="M20 21a8 8 0 1 0-16 0"/>')}
function iconBarChart(){return icon('<line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/>')}
function iconUpload(){return icon('<polyline points="16 16 12 12 8 16"/><line x1="12" y1="12" x2="12" y2="21"/><path d="M20.39 18.39A5 5 0 0 0 18 9h-1.26A8 8 0 1 0 3 16.3"/>')}
function iconUsers(){return icon('<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>')}
function iconBook(){return icon('<path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>')}
function iconSettings(){return icon('<circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/>')}
function iconPlus(){return`<svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>`}
function iconEdit(){return`<svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>`}
function iconTrash(){return`<svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6M14 11v6"/><path d="M9 6V4h6v2"/></svg>`}
function iconDown(){return`<svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>`}

// ═══════════════════════════════════════════════════════════════════════
//  AUTH
// ═══════════════════════════════════════════════════════════════════════
// ── Login / Signup UI toggles ──────────────────────────────────────────────
function showSignup(){
  document.getElementById('login-card').classList.add('hidden');
  document.getElementById('signup-card').classList.remove('hidden');
  clearAuthErrors();
}
function showLogin(){
  document.getElementById('signup-card').classList.add('hidden');
  document.getElementById('login-card').classList.remove('hidden');
  clearAuthErrors();
}
function clearAuthErrors(){
  ['login-error','signup-error'].forEach(id=>{
    const el = document.getElementById(id);
    el.classList.add('hidden'); el.textContent='';
  });
}
function showError(id, msg){
  const el = document.getElementById(id);
  el.textContent = msg; el.classList.remove('hidden');
}
function togglePwd(id, eye){
  const inp = document.getElementById(id);
  inp.type = inp.type === 'password' ? 'text' : 'password';
  eye.textContent = inp.type === 'password' ? '👁' : '🙈';
}
function fillLogin(id, pw){
  document.getElementById('login-identifier').value = id;
  document.getElementById('login-password').value = pw;
}
function detectRoleHint(val){
  const hint = document.getElementById('su-role-hint');
  const roleColors = {student:'#2563d4', lecturer:'#0f7a5a'};
  const roleLabels = {student:'Student account', lecturer:'Lecturer account'};
  let role = null;
  if(/^\d{4}\/[A-Z]+\/\d+$/i.test(val)) role='student';
  else if(/^STF-/i.test(val)) role='lecturer';
  if(role){
    hint.textContent = '✓ Detected as ' + roleLabels[role];
    hint.style.color = roleColors[role];
    hint.classList.remove('hidden');
  } else {
    hint.classList.add('hidden');
  }
}

// ── Login ──────────────────────────────────────────────────────────────────
async function doLogin(){
  const identifier = document.getElementById('login-identifier').value.trim();
  const password   = document.getElementById('login-password').value;
  const btnText    = document.getElementById('login-btn-text');
  clearAuthErrors();
  if(!identifier || !password){ showError('login-error','Please fill in all fields.'); return; }
  btnText.textContent = 'Signing in…';
  try {
    const res = await fetch('/api/auth/login', {
      method:'POST', headers:{'Content-Type':'application/json'},
      body: JSON.stringify({identifier, password})
    });
    const json = await res.json();
    if(!json.success){ showError('login-error', json.error || 'Login failed.'); btnText.textContent='Sign in'; return; }
    currentUser = json.data;
    currentRole = json.data.role;
    document.getElementById('login-page').classList.add('hidden');
    document.getElementById('app').classList.remove('hidden');
    initApp();
  } catch(e){
    showError('login-error','Could not connect to server.');
    btnText.textContent='Sign in';
  }
}

// ── Signup ─────────────────────────────────────────────────────────────────
async function doSignup(){
  const identifier = document.getElementById('su-identifier').value.trim();
  const name       = document.getElementById('su-name').value.trim();
  const email      = document.getElementById('su-email').value.trim();
  const department = document.getElementById('su-dept').value.trim();
  const password   = document.getElementById('su-password').value;
  const btnText    = document.getElementById('signup-btn-text');
  clearAuthErrors();
  if(!identifier||!name||!email||!password){ showError('signup-error','Please fill in all fields.'); return; }
  btnText.textContent = 'Creating account…';
  try {
    const res = await fetch('/api/auth/signup', {
      method:'POST', headers:{'Content-Type':'application/json'},
      body: JSON.stringify({identifier, name, email, password, department})
    });
    const json = await res.json();
    if(!json.success){ showError('signup-error', json.error || 'Signup failed.'); btnText.textContent='Create account'; return; }
    currentUser = json.data;
    currentRole = json.data.role;
    document.getElementById('login-page').classList.add('hidden');
    document.getElementById('app').classList.remove('hidden');
    initApp();
  } catch(e){
    showError('signup-error','Could not connect to server.');
    btnText.textContent='Create account';
  }
}

// ── Logout ─────────────────────────────────────────────────────────────────
async function doLogout(){
  await fetch('/api/auth/logout', {method:'POST'});
  currentUser = null; currentRole = null;
  document.getElementById('app').classList.add('hidden');
  document.getElementById('login-page').classList.remove('hidden');
  document.getElementById('app').className = 'hidden';
  showLogin();
}

// ═══════════════════════════════════════════════════════════════════════
//  APP INIT
// ═══════════════════════════════════════════════════════════════════════
let currentUser = null;
const roleClass  = {student:'role-student', lecturer:'role-lecturer', admin:'role-admin'};
const roleColors = {student:'#2563d4', lecturer:'#0f7a5a', admin:'#b45309'};
const roleLabels = {student:'Student', lecturer:'Lecturer', admin:'Admin'};

function initApp(){
  const u = currentUser;
  const role = currentRole;
  // Sub-label under name in sidebar
  const sub = role === 'student'
    ? `${u.level || ''} · ${u.department || ''}`
    : role === 'lecturer'
    ? `Dept. of ${u.department || ''}`
    : `${u.department || ''} · Administration`;

  document.getElementById('app').className = roleClass[role];
  document.getElementById('sb-logo').style.background = roleColors[role];
  document.getElementById('sb-role-badge').textContent = roleLabels[role];
  document.getElementById('sb-avatar').textContent = u.initials || u.name.slice(0,2).toUpperCase();
  document.getElementById('sb-avatar').style.background = roleColors[role];
  document.getElementById('sb-user-name').textContent = u.name;
  document.getElementById('sb-user-role').textContent = sub;
  buildNav();
  navigate('dashboard');
}

function buildNav(){
  const nav = document.getElementById('sidebar-nav');
  const cfg = NAV_CONFIG[currentRole];
  let html = '';
  cfg.forEach(sec => {
    html += `<div class="nav-section-label">${sec.section}</div>`;
    sec.items.forEach(item => {
      html += `<div class="nav-item" id="nav-${item.id}" onclick="navigate('${item.id}')">${item.icon()}<span>${item.label}</span></div>`;
    });
  });
  nav.innerHTML = html;
}

function navigate(pageId){
  currentPage = pageId;
  // update nav active
  document.querySelectorAll('.nav-item').forEach(el=>el.classList.remove('active'));
  const navEl = document.getElementById(`nav-${pageId}`);
  if(navEl) navEl.classList.add('active');
  // update topbar
  const allItems = NAV_CONFIG[currentRole].flatMap(s=>s.items);
  const item = allItems.find(i=>i.id===pageId);
  document.getElementById('topbar-title').textContent = item ? item.label : pageId;
  // render page
  const content = document.getElementById('page-content');
  content.scrollTop = 0;
  content.innerHTML = '<div class="page-fade">' + loadingSkeleton() + '</div>';
  if(currentRole === 'lecturer'){
    hydrateLecturerPage(pageId);
  } else if(currentRole === 'admin'){
    hydrateAdminPage(pageId);
  } else {
    hydrateStudentPage(pageId);
  }
}

// ═══════════════════════════════════════════════════════════════════════
//  PAGE RENDERER
// ═══════════════════════════════════════════════════════════════════════
function renderPage(id){
  if(currentRole === 'student')  return renderStudentPage(id);
  if(currentRole === 'lecturer') return renderLecturerPage(id);
  if(currentRole === 'admin')    return renderAdminPage(id);
  return '<p>Unknown role</p>';
}

// ═══════════════════════════════════════════════════════════════════════
//  ████████  STUDENT PAGES  (dynamic — all data from /api/student/*)
// ═══════════════════════════════════════════════════════════════════════

// ── shared API helper ─────────────────────────────────────────────────
async function apiFetch(path) {
  const res = await fetch(path, { credentials: 'include' });
  const json = await res.json();
  if (!json.success) throw new Error(json.error || 'API error');
  return json.data;
}

// ── loading / error skeletons ─────────────────────────────────────────
function loadingSkeleton() {
  return `<div style="display:flex;align-items:center;justify-content:center;height:200px;color:var(--text3);font-size:13px">
    <div style="text-align:center">
      <div style="width:32px;height:32px;border:3px solid var(--border);border-top-color:var(--accent);border-radius:50%;animation:spin .8s linear infinite;margin:0 auto 12px"></div>
      Loading…
    </div>
  </div>`;
}
function errorBanner(msg) {
  return `<div style="background:#fee2e2;border:1px solid #fca5a5;border-radius:8px;padding:14px;font-size:13px;color:#b91c1c;margin-bottom:20px">⚠️ ${msg}</div>`;
}

// ── navigate override: render skeleton immediately, then hydrate ───────
function renderStudentPage(id) {
  // Render a loading shell instantly so the page feels snappy
  setTimeout(() => hydrateStudentPage(id), 0);
  return loadingSkeleton();
}

async function hydrateStudentPage(id) {
  const content = document.getElementById('page-content');
  try {
    let html = '';
    if      (id === 'dashboard')     html = await studentDashboard();
    else if (id === 'notifications') html = await studentNotifications();
    else if (id === 'courses')       html = await studentCourses();
    else if (id === 'attendance')    html = await studentAttendance();
    else if (id === 'grades')        html = await studentGrades();
    else if (id === 'transcript')    html = await studentTranscript();
    else if (id === 'course-detail') html = await studentCourseDetail();
    else if (id === 'profile')       html = profileSettings();
    else html = '<p>Page not found</p>';
    content.innerHTML = `<div class="page-fade">${html}</div>`;
  } catch(e) {
    content.innerHTML = `<div class="page-fade">${errorBanner('Failed to load page: ' + e.message)}</div>`;
  }
}

async function studentDashboard(){
  const d = await apiFetch('/api/student/dashboard');
  const u = d.user;
  const s = d.stats;
  const firstName = u.name.split(' ')[0];

  const todaySlots = d.today_schedule.map(c =>
    `<div class="schedule-slot">
      <div class="slot-time">${c.time}</div>
      <div class="slot-bar" style="background:var(--accent)"></div>
      <div><div class="slot-title">${c.course}</div></div>
    </div>`
  ).join('') || '<p style="font-size:13px;color:var(--text3)">No classes today.</p>';

  const attRows = d.today_schedule.slice(0,4).map(c =>
    `<div style="display:flex;align-items:center;gap:10px;padding:8px 0;border-bottom:1px solid var(--border)">
      <span style="font-family:var(--mono);font-size:12px;color:var(--accent);flex-shrink:0">${c.course}</span>
    </div>`
  ).join('');

  const notifRows = (d.recent_notifications || []).map(n =>
    miniNotif(n.icon, n.title, n.desc, n.time)
  ).join('') || '<p style="font-size:13px;color:var(--text3)">No new notifications.</p>';

  // fetch attendance + grades for summary cards
  const att  = await apiFetch('/api/student/attendance');
  const grd  = await apiFetch('/api/student/grades');

  const attSummary = att.courses.slice(0,4).map(c =>
    attRow(c.code, c.attended, c.total, c.rate + '%', c.status)
  ).join('');

  const gradeSummary = grd.courses.slice(0,4).map(c =>
    gradeRow(c.code, c.total, c.grade)
  ).join('');

  return `
  <div class="page-header">
    <div>
      <div class="page-title">Good morning, ${firstName} 👋</div>
      <div class="page-subtitle">${d.semester || '2024/2025 Semester 1'} · Week ${d.week || 11}</div>
    </div>
  </div>
  <div class="grid-4" style="margin-bottom:24px">
    ${statCard('Attendance Rate', s.overall_attendance, 'Across all courses', 'good')}
    ${statCard('Enrolled Courses', s.enrolled_courses ?? '—', `${d.semester || '2024/2025 Semester 1'}`, 'neutral')}
    ${statCard('Current GPA', s.semester_gpa + ' / 5.0', 'This semester', s.semester_gpa >= 3.5 ? 'good' : s.semester_gpa >= 2.5 ? 'warn' : 'bad')}
    ${statCard('At-Risk Courses', s.at_risk_courses, 'Below 70% attendance', s.at_risk_courses > 0 ? 'bad' : 'good')}
  </div>
  <div class="grid-2" style="margin-bottom:24px">
    <div class="card">
      <div class="card-title">Today's Classes</div>
      ${todaySlots}
    </div>
    <div class="card">
      <div class="card-title">Recent Notifications</div>
      ${notifRows}
    </div>
  </div>
  <div class="grid-2">
    <div class="card">
      <div class="card-title">Attendance Summary</div>
      ${attSummary}
      <button class="btn btn-ghost btn-sm" style="margin-top:12px" onclick="navigate('attendance')">View all attendance →</button>
    </div>
    <div class="card">
      <div class="card-title">Grade Overview</div>
      ${gradeSummary}
      <button class="btn btn-ghost btn-sm" style="margin-top:12px" onclick="navigate('grades')">View full results →</button>
    </div>
  </div>`;
}

// ── Courses & Timetable ───────────────────────────────────────────────────
async function studentCourses(){
  const d = await apiFetch('/api/student/courses');
  const count = d.courses.length;
  return `
  <div class="page-header">
    <div><div class="page-title">Courses & Timetable</div><div class="page-subtitle">2024/2025 Semester 1 · ${count} courses enrolled</div></div>
    <div class="flex gap-2">
      <button class="btn btn-outline" onclick="setCourseView('list',${JSON.stringify(d.courses).replace(/"/g,'&quot;')})">List</button>
      <button class="btn btn-primary" onclick="setCourseView('week',${JSON.stringify(d.timetable_events).replace(/"/g,'&quot;')})">Weekly View</button>
    </div>
  </div>
  <div id="course-view-container">${renderCourseList(d.courses)}</div>`;
}

function renderCourseList(courses){
  const rows = courses.map(c=>`<tr>
    <td><span style="font-family:var(--mono);font-size:12px;font-weight:500;color:var(--accent)">${c.code}</span></td>
    <td><span class="font-medium" style="cursor:pointer;color:var(--accent)" onclick="navigate('course-detail')">${c.name}</span></td>
    <td class="text-muted">${c.lecturer}</td>
    <td class="text-muted">${c.days} ${c.time}</td>
    <td class="text-muted">${c.venue}</td>
    <td><span class="badge ${c.status==='active'?'badge-green':'badge-gray'}">${c.status==='active'?'Active':'Completed'}</span></td>
  </tr>`).join('');
  return `<div class="tbl-wrap"><table><thead><tr><th>Code</th><th>Course</th><th>Lecturer</th><th>Schedule</th><th>Venue</th><th>Status</th></tr></thead><tbody>${rows}</tbody></table></div>`;
}

function setCourseView(v, data){
  const container = document.getElementById('course-view-container');
  if(v === 'list') container.innerHTML = renderCourseList(typeof data === 'string' ? JSON.parse(data) : data);
  else container.innerHTML = renderWeekView(typeof data === 'string' ? JSON.parse(data) : data);
}

function renderWeekView(events){
  const days  = ['Mon','Tue','Wed','Thu','Fri'];
  const slots = ['08:00','09:00','10:00','11:00','12:00','13:00','14:00','15:00','16:00'];
  // Build a lookup map from the API events array
  const evMap = {};
  (events || []).forEach(e => { evMap[`${e.day}-${e.time}`] = e; });
  let html = `<div class="week-cal"><div class="cal-head"></div>${days.map(d=>`<div class="cal-head">${d}</div>`).join('')}`;
  slots.forEach(t => {
    html += `<div class="cal-time">${t}</div>`;
    days.forEach(d => {
      const ev = evMap[`${d}-${t}`];
      html += `<div class="cal-cell">${ev?`<div class="cal-event" style="background:${ev.color};color:${ev.tc}">${ev.label}</div>`:''}</div>`;
    });
  });
  return html + '</div>';
}

// ── Course detail ─────────────────────────────────────────────────────────
// Stores the last clicked course code so detail page knows what to load
let _currentCourseCode = 'CSC-301';

async function studentCourseDetail(){
  const d = await apiFetch(`/api/student/course/${_currentCourseCode}`);
  const c = d.course;
  const att = d.attendance;
  const grade = d.grade;
  const attRate = att ? att.rate + '%' : '—';
  const attSub  = att ? `${att.attended} of ${att.total} classes` : '—';
  const scoreVal = grade ? `${grade.total}/100` : '—';
  const gradeLetter = grade ? `Grade: ${grade.grade}` : '—';
  const materials = (d.materials || []).map(m => materialRow(m.icon, m.name, m.meta)).join('') ||
    '<p style="font-size:13px;color:var(--text3)">No materials uploaded yet.</p>';
  const assessments = grade ? `
    ${scoreRow('Continuous Assessment', grade.ca, 40, Math.round(grade.ca/40*100)+'%')}
    ${scoreRow('Exam Score', grade.exam, 60, Math.round(grade.exam/60*100)+'%')}
    <div style="margin-top:16px;padding-top:12px;border-top:1px solid var(--border)">
      <div class="flex justify-between" style="font-size:13px">
        <span class="font-medium">Total</span>
        <span class="font-medium" style="color:var(--accent)">${grade.total} / 100 (${grade.grade})</span>
      </div>
    </div>` : '<p style="font-size:13px;color:var(--text3)">Grades not yet released.</p>';

  return `
  <div class="breadcrumb"><span class="breadcrumb-sep">←</span><a onclick="navigate('courses')">Courses</a><span class="breadcrumb-sep">/</span><span>${c.code}</span></div>
  <div class="course-header">
    <div class="course-header-code">${c.code} · ${c.units} Units</div>
    <div class="course-header-name">${c.name}</div>
    <div class="course-header-meta">${c.lecturer} · ${c.venue} · ${c.days} ${c.time}</div>
  </div>
  <div class="tab-bar">
    <div class="tab active">Overview</div>
    <div class="tab">Materials</div>
    <div class="tab">Assessments</div>
    <div class="tab">Attendance</div>
  </div>
  <div class="grid-2" style="margin-bottom:20px">
    ${statCard('Attendance', attRate, attSub, att && att.rate >= 70 ? 'good' : 'bad')}
    ${statCard('Current Score', scoreVal, gradeLetter, grade && grade.grade === 'A' ? 'good' : grade && grade.grade === 'C' ? 'warn' : 'neutral')}
  </div>
  <div class="grid-2">
    <div class="card"><div class="card-title">Course Materials</div>${materials}</div>
    <div class="card"><div class="card-title">Assessment Breakdown</div>${assessments}</div>
  </div>`;
}

// ── Attendance ────────────────────────────────────────────────────────────
async function studentAttendance(){
  const d = await apiFetch('/api/student/attendance');
  const s = d.summary;
  const rows = d.courses.map(c=>`<tr>
    <td><span style="font-family:var(--mono);font-size:12px;color:var(--accent)">${c.code}</span></td>
    <td>${c.name}</td><td>${c.attended}</td><td>${c.total}</td><td>${c.total-c.attended}</td>
    <td>
      <div style="display:flex;align-items:center;gap:8px">
        <div style="width:70px"><div class="progress-bar"><div class="progress-fill ${c.status==='good'?'green':c.status==='bad'?'red':'amber'}" style="width:${c.rate}%"></div></div></div>
        <span style="font-size:12px;font-family:var(--mono)">${c.rate}%</span>
      </div>
    </td>
    <td><span class="badge ${c.status==='good'?'badge-green':c.status==='bad'?'badge-red':'badge-amber'}">${c.status==='good'?'Good':c.status==='bad'?'At Risk':'Satisfactory'}</span></td>
  </tr>`).join('');

  const atRiskCourses = d.courses.filter(c => c.status === 'bad');
  const warningCards = atRiskCourses.map(c => `
    <div class="card" style="margin-top:12px">
      <div class="card-title">${c.code} — Attendance Warning</div>
      <div style="background:#fef3c7;border:1px solid #fde68a;border-radius:8px;padding:14px;font-size:13px;color:#78350f">
        ⚠️ Your attendance in <strong>${c.code} ${c.name}</strong> is ${c.rate}%, which is below the required 70% minimum.
      </div>
    </div>`).join('');

  return `
  <div class="page-header">
    <div><div class="page-title">My Attendance</div><div class="page-subtitle">${d.semester}</div></div>
  </div>
  <div class="grid-4" style="margin-bottom:24px">
    ${statCard('Overall Rate', s.overall_rate, 'Across all courses', parseFloat(s.overall_rate) >= 70 ? 'good' : 'bad')}
    ${statCard('Classes Attended', s.classes_attended, `Out of ${s.total_classes} total`, 'neutral')}
    ${statCard('Absent', s.absent, 'Total missed classes', s.absent > 5 ? 'warn' : 'neutral')}
    ${statCard('At-Risk Courses', s.at_risk_count, 'Below 70% threshold', s.at_risk_count > 0 ? 'bad' : 'good')}
  </div>
  <div class="tbl-wrap">
    <table><thead><tr><th>Code</th><th>Course</th><th>Attended</th><th>Total</th><th>Absent</th><th>Rate</th><th>Status</th></tr></thead>
    <tbody>${rows}</tbody></table>
  </div>
  ${warningCards}`;
}

// ── Grades ────────────────────────────────────────────────────────────────
async function studentGrades(){
  const d = await apiFetch('/api/student/grades');
  const s = d.summary;
  const gradeCols = {A:'badge-green',B:'badge-blue',C:'badge-amber',D:'badge-red',F:'badge-red'};
  const gp = {A:5,B:4,C:3,D:2,F:0};
  const rows = d.courses.map(c=>`<tr>
    <td><span style="font-family:var(--mono);font-size:12px;color:var(--accent)">${c.code}</span></td>
    <td>${c.name}</td><td class="text-muted">${c.units}</td>
    <td><span style="font-family:var(--mono)">${c.ca}/40</span></td>
    <td><span style="font-family:var(--mono)">${c.exam}/60</span></td>
    <td><span style="font-family:var(--mono);font-weight:500">${c.total}</span></td>
    <td><span class="badge ${gradeCols[c.grade]||'badge-gray'}">${c.grade}</span></td>
    <td><span style="font-family:var(--mono)">${(gp[c.grade]||0)*c.units}</span></td>
  </tr>`).join('');
  return `
  <div class="page-header">
    <div><div class="page-title">Grades & Results</div><div class="page-subtitle">${d.semester}</div></div>
    <button class="btn btn-outline" onclick="navigate('transcript')">${iconDown()} Download Transcript</button>
  </div>
  <div class="grid-4" style="margin-bottom:24px">
    ${statCard('Semester GPA', s.semester_gpa, d.semester, s.semester_gpa >= 3.5 ? 'good' : 'warn')}
    ${statCard('Cumulative GPA', s.cumulative_gpa, 'Overall performance', s.cumulative_gpa >= 3.5 ? 'good' : 'warn')}
    ${statCard('Credits Earned', s.credits_earned, 'This semester', 'neutral')}
    ${statCard('Distinctions', s.distinctions, 'Courses with A grade', s.distinctions > 0 ? 'good' : 'neutral')}
  </div>
  <div class="tbl-wrap">
    <table><thead><tr><th>Code</th><th>Course</th><th>Units</th><th>CA /40</th><th>Exam /60</th><th>Total</th><th>Grade</th><th>GP</th></tr></thead>
    <tbody>${rows}</tbody></table>
  </div>`;
}

// ── Transcript ────────────────────────────────────────────────────────────
async function studentTranscript(){
  const d = await apiFetch('/api/student/transcript');
  const st = d.student;
  const semesterBlocks = d.semesters.map(sem =>
    transcriptSemester(sem.label, sem.gpa, sem.units, sem.courses)
  ).join('');
  return `
  <div class="page-header">
    <div><div class="page-title">Official Transcript</div><div class="page-subtitle">University of Lagos — Academic Record</div></div>
    <div class="flex gap-2">
      <button class="btn btn-outline">${iconDown()} Download PDF</button>
      <button class="btn btn-primary">Request Official Copy</button>
    </div>
  </div>
  <div class="report-card">
    <div class="report-header">
      <div style="font-size:18px;font-weight:600;color:var(--text);margin-bottom:2px">University of Lagos</div>
      <div style="font-size:13px;color:var(--text2)">Official Academic Transcript — Strictly Confidential</div>
    </div>
    <div class="report-body">
      <div class="grid-2" style="margin-bottom:20px">
        <div>
          ${reportRow('Student Name', st.name)}
          ${reportRow('Matric Number', st.matric)}
          ${reportRow('Department', st.department)}
          ${reportRow('Faculty', st.faculty || '—')}
        </div>
        <div>
          ${reportRow('Level', st.level)}
          ${reportRow('Mode of Entry', st.mode_of_entry || '—')}
          ${reportRow('Date of Admission', st.admission_date || '—')}
          ${reportRow('Cumulative GPA', (st.cumulative_gpa || '—') + ' / 5.0')}
        </div>
      </div>
      <div style="font-weight:600;font-size:13px;margin-bottom:12px;padding-bottom:6px;border-bottom:1px solid var(--border)">Academic History</div>
      ${semesterBlocks}
    </div>
  </div>`;
}

// ── Notifications ─────────────────────────────────────────────────────────
async function studentNotifications(){
  const d = await apiFetch('/api/student/notifications');
  const items = d.notifications;
  const unreadCount = d.unread_count;
  return `
  <div class="page-header">
    <div><div class="page-title">Notifications</div><div class="page-subtitle">${unreadCount} unread</div></div>
    <button class="btn btn-ghost btn-sm" onclick="markAllNotificationsRead(this)">Mark all as read</button>
  </div>
  <div class="card" id="notif-list">
    ${items.map(n=>`
    <div class="notif-item" id="notif-${n.id}">
      <div class="notif-dot-icon ${n.unread?'':'read'}"></div>
      <div class="notif-body">
        <div class="flex justify-between items-start">
          <div class="notif-title">${n.icon} ${n.title}</div>
          <span class="badge badge-gray text-xs" style="margin-left:8px;flex-shrink:0">${n.tag}</span>
        </div>
        <div class="notif-desc">${n.desc}</div>
        <div class="notif-time">${n.time}</div>
      </div>
    </div>`).join('')}
  </div>`;
}

async function markAllNotificationsRead(btn){
  btn.disabled = true;
  btn.textContent = 'Marking…';
  await fetch('/api/student/notifications/read-all', {method:'POST', credentials:'include'});
  // Update dots to read
  document.querySelectorAll('.notif-dot-icon').forEach(el => el.classList.add('read'));
  document.querySelector('.page-subtitle').textContent = '0 unread';
  btn.textContent = 'All read';
}

