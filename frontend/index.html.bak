  </div>
  <div class="tbl-wrap">
    <table><thead><tr><th>Course</th><th>Lecturer</th><th>Day(s)</th><th>Time</th><th>Venue</th><th>Students</th><th>Actions</th></tr></thead>
    <tbody>
      ${ttRow('CSC 301','Dr. Eze','Mon/Wed','08:00–09:30','Hall B','87')}
      ${ttRow('MTH 202','Dr. Adaora','Tue/Thu','11:00–12:30','LT 1','120')}
      ${ttRow('ENG 210','Mr. Chidi','Fri','14:00–16:00','Room 14A','95')}
      ${ttRow('PHY 305','Prof. Bello','Mon/Thu','13:00–14:30','LT 2','80')}
      ${ttRow('CSC 401','Dr. Eze','Tue/Thu','14:00–15:30','Room 3A','54')}
    </tbody></table>
  </div>`;
}

function adminAttOverview(){
  const depts=[
    {dept:'Computer Science',students:620,avg:'83%',atrisk:12,perfect:45,rate:83},
    {dept:'Mathematics',students:540,avg:'79%',atrisk:18,perfect:30,rate:79},
    {dept:'Physics',students:380,avg:'77%',atrisk:15,perfect:22,rate:77},
    {dept:'Engineering',students:890,avg:'82%',atrisk:20,perfect:60,rate:82},
    {dept:'Economics',students:460,avg:'80%',atrisk:10,perfect:38,rate:80},
  ];
  const rows=depts.map(d=>`<tr>
    <td class="font-medium">${d.dept}</td><td>${d.students}</td>
    <td>
      <div class="flex items-center gap-2">
        <div style="width:80px"><div class="progress-bar"><div class="progress-fill ${d.rate>=80?'green':'amber'}" style="width:${d.rate}%"></div></div></div>
        <span style="font-size:12px;font-family:var(--mono)">${d.avg}</span>
      </div>
    </td>
    <td><span class="badge badge-red">${d.atrisk}</span></td>
    <td><span class="badge badge-green">${d.perfect}</span></td>
    <td><button class="btn btn-ghost btn-sm">View Details</button></td>
  </tr>`).join('');
  return `
  <div class="page-header">
    <div><div class="page-title">Attendance Overview</div><div class="page-subtitle">Campus-wide attendance summary</div></div>
    <button class="btn btn-outline">${iconDown()} Export Report</button>
  </div>
  <div class="grid-4" style="margin-bottom:24px">
    ${statCard('Campus Average','81%','Target: 75%','good')}
    ${statCard('At-Risk Students','87','Below 70%','bad')}
    ${statCard('Perfect Attendance','214','100% rate','good')}
    ${statCard('Chronic Absentees','23','Flagged for review','bad')}
  </div>
  <div class="tbl-wrap">
    <table><thead><tr><th>Department</th><th>Students</th><th>Avg. Rate</th><th>At Risk</th><th>Perfect</th><th></th></tr></thead>
    <tbody>${rows}</tbody></table>
  </div>`;
}

function adminGrades(){
  const data=[
    {code:'CSC 301',name:'Algorithms',lecturer:'Dr. Eze',students:87,submitted:true,approved:'pending'},
    {code:'MTH 202',name:'Calculus II',lecturer:'Dr. Adaora',students:120,submitted:false,approved:'—'},
    {code:'ENG 210',name:'Technical Writing',lecturer:'Mr. Chidi',students:95,submitted:true,approved:'approved'},
    {code:'PHY 305',name:'Electromagnetism',lecturer:'Prof. Bello',students:80,submitted:true,approved:'pending'},
    {code:'CSC 401',name:'Advanced Algorithms',lecturer:'Dr. Eze',students:54,submitted:false,approved:'—'},
  ];
  const rows=data.map(c=>`<tr>
    <td><span style="font-family:var(--mono);font-size:12px;color:var(--accent)">${c.code}</span></td>
    <td class="font-medium">${c.name}</td><td class="text-muted">${c.lecturer}</td><td>${c.students}</td>
    <td><span class="badge ${c.submitted?'badge-green':'badge-red'}">${c.submitted?'Submitted':'Pending'}</span></td>
    <td><span class="badge ${c.approved==='approved'?'badge-green':c.approved==='pending'?'badge-amber':'badge-gray'}">${c.approved==='approved'?'Approved':c.approved==='pending'?'Pending':'—'}</span></td>
    <td><div class="flex gap-2">
      ${c.submitted&&c.approved==='pending'?`<button class="btn btn-primary btn-sm" onclick="approveGrades(this)">Approve</button>`:
        c.submitted&&c.approved==='approved'?`<span class="text-sm text-muted">Approved ✓</span>`:
        `<button class="btn btn-outline btn-sm" disabled>Awaiting submission</button>`}
    </div></td>
  </tr>`).join('');
  return `
  <div class="page-header">
    <div><div class="page-title">Grades Management</div><div class="page-subtitle">Review and approve submitted grades</div></div>
    <button class="btn btn-outline">${iconDown()} Export All Grades</button>
  </div>
  <div class="grid-4" style="margin-bottom:24px">
    ${statCard('Courses','62','Active this semester','neutral')}
    ${statCard('Grades Submitted','47','76% completion','warn')}
    ${statCard('Approved','41','Of submitted','good')}
    ${statCard('Pending Approval','6','Awaiting review','warn')}
  </div>
  <div class="tbl-wrap">
    <table><thead><tr><th>Code</th><th>Course</th><th>Lecturer</th><th>Students</th><th>Submitted</th><th>Status</th><th>Action</th></tr></thead>
    <tbody>${rows}</tbody></table>
  </div>`;
}

function approveGrades(btn){
  btn.textContent='Approving…';btn.disabled=true;
  setTimeout(()=>{btn.closest('td').innerHTML='<span class="text-sm text-muted">Approved ✓</span>';},700);
}

function adminBroadcast(){
  return `
  <div class="page-header">
    <div><div class="page-title">Broadcast Notification</div><div class="page-subtitle">Send announcements to students, lecturers, or all users</div></div>
  </div>
  <div class="grid-2">
    <div class="card">
      <div class="card-title">Compose Broadcast</div>
      <div class="form-group">
        <div class="form-label">Recipients</div>
        <div class="checkbox-row"><input type="checkbox" id="rec-all" checked/><label for="rec-all">All users (students + lecturers + admin)</label></div>
        <div class="checkbox-row"><input type="checkbox" id="rec-stu"/><label for="rec-stu">Students only</label></div>
        <div class="checkbox-row"><input type="checkbox" id="rec-lec"/><label for="rec-lec">Lecturers / Staff only</label></div>
        <div class="checkbox-row"><input type="checkbox" id="rec-dept"/><label for="rec-dept">Specific department</label></div>
      </div>
      <div class="form-group">
        <label class="form-label">Priority</label>
        <select class="form-input form-select">
          <option>Normal</option>
          <option>Important</option>
          <option>Urgent</option>
        </select>
      </div>
      <div class="form-group">
        <label class="form-label">Subject</label>
        <input class="form-input" type="text" placeholder="Notification subject"/>
      </div>
      <div class="form-group">
        <label class="form-label">Message</label>
        <textarea class="form-input form-textarea" placeholder="Type your announcement here…"></textarea>
      </div>
      <div class="flex gap-2">
        <button class="btn btn-primary" onclick="sendBroadcast()">Send Broadcast</button>
        <button class="btn btn-outline">Schedule for later</button>
      </div>
    </div>
    <div>
      <div class="card" style="margin-bottom:16px">
        <div class="card-title">Estimated Reach</div>
        <div style="display:flex;flex-direction:column;gap:8px">
          ${reachRow('All Students','4,820','badge-blue')}
          ${reachRow('All Lecturers','148','badge-green')}
          ${reachRow('Admin Staff','12','badge-amber')}
          <div style="padding-top:8px;border-top:1px solid var(--border);font-size:13px;font-weight:600">Total: 4,980 recipients</div>
        </div>
      </div>
      <div class="card">
        <div class="card-title">Recent Broadcasts</div>
        ${miniNotif('📢','Campus Closure — Mar 25','Sent to all users','3 days ago')}
        ${miniNotif('📋','Exam Timetable Released','Sent to students','Last week')}
        ${miniNotif('📣','Registration Deadline','Sent to students','2 weeks ago')}
      </div>
    </div>
  </div>`;
}

function sendBroadcast(){alert('Broadcast sent successfully to all recipients!');}

function adminSettings(){
  return `
  <div class="page-header">
    <div><div class="page-title">System Settings</div><div class="page-subtitle">Manage academic year and system configuration</div></div>
  </div>
  <div class="grid-2">
    <div class="card" style="margin-bottom:16px">
      <div class="card-title">Academic Calendar</div>
      ${settingField('Academic Year','2024 / 2025')}
      ${settingField('Current Semester','Semester 1')}
      ${settingField('Semester Start','September 2, 2024')}
      ${settingField('Semester End','April 30, 2025')}
      ${settingField('Exam Period','April 1–30, 2025')}
    </div>
    <div class="card" style="margin-bottom:16px">
      <div class="card-title">Grading Configuration</div>
      ${settingField('CA Weight','40%')}
      ${settingField('Exam Weight','60%')}
      ${settingField('Minimum Pass Score','45 / 100')}
      ${settingField('Grade Scale','A=70+, B=60–69, C=50–59, D=45–49')}
    </div>
  </div>
  <div class="card" style="margin-bottom:16px">
    <div class="card-title">System Toggles</div>
    ${toggle('Allow Grade Edits','Lecturers can modify submitted grades',true)}
    ${toggle('Email Notifications','Send email alerts for new announcements',true)}
    ${toggle('Student Grade View','Students can view their results',true)}
    ${toggle('Attendance Alerts','Auto-notify at-risk students',true)}
    ${toggle('Registration Portal','Open for new semester registration',false)}
    ${toggle('Maintenance Mode','Take system offline for maintenance',false)}
  </div>
  <div class="card">
    <div class="card-title">Attendance Policy</div>
    ${settingField('Minimum Attendance','70% required for exam eligibility')}
    ${settingField('At-Risk Threshold','Below 70%')}
    ${settingField('Auto-Alert Trigger','When student drops below 75%')}
    <button class="btn btn-primary" style="margin-top:16px">Save Settings</button>
  </div>`;
}

// ═══════════════════════════════════════════════════════════════════════
//  SHARED PAGES
// ═══════════════════════════════════════════════════════════════════════
function profileSettings(){
  const u=USERS[currentRole];
  return `
  <div class="page-header">
    <div><div class="page-title">Profile & Settings</div><div class="page-subtitle">Manage your account information</div></div>
    <button class="btn btn-primary">Save Changes</button>
  </div>
  <div class="grid-2">
    <div class="card">
      <div class="card-title">Personal Information</div>
      <div style="display:flex;align-items:center;gap:16px;margin-bottom:20px">
        <div style="width:64px;height:64px;border-radius:50%;background:var(--accent);display:flex;align-items:center;justify-content:center;font-size:22px;font-weight:600;color:#fff;flex-shrink:0">${u.initials}</div>
        <div>
          <div class="font-semibold" style="font-size:16px">${u.name}</div>
          <div class="text-muted text-sm">${u.sub}</div>
          <button class="btn btn-ghost btn-sm" style="margin-top:4px;padding-left:0">Change photo</button>
        </div>
      </div>
      <div class="form-group"><label class="form-label">Full Name</label><input class="form-input" value="${u.name}"/></div>
      <div class="form-group"><label class="form-label">Email Address</label><input class="form-input" value="${u.email}"/></div>
      <div class="form-group"><label class="form-label">Phone Number</label><input class="form-input" placeholder="+234 …"/></div>
    </div>
    <div>
      <div class="card" style="margin-bottom:16px">
        <div class="card-title">Security</div>
        <div class="form-group"><label class="form-label">Current Password</label><input class="form-input" type="password" placeholder="••••••••"/></div>
        <div class="form-group"><label class="form-label">New Password</label><input class="form-input" type="password" placeholder="••••••••"/></div>
        <div class="form-group"><label class="form-label">Confirm New Password</label><input class="form-input" type="password" placeholder="••••••••"/></div>
        <button class="btn btn-outline">Update Password</button>
      </div>
      <div class="card">
        <div class="card-title">Notification Preferences</div>
        ${toggle('Email Notifications','Receive updates via email',true)}
        ${toggle('Grade Alerts','Notify when grades are released',true)}
        ${toggle('Attendance Alerts','Warn when attendance drops',true)}
        ${toggle('Announcement Digest','Weekly summary of announcements',false)}
      </div>
    </div>
  </div>`;
}

// ═══════════════════════════════════════════════════════════════════════
//  HELPER COMPONENTS
// ═══════════════════════════════════════════════════════════════════════
function statCard(label,value,sub,type){
  const cols={good:'#22c55e',bad:'#ef4444',warn:'#f59e0b',neutral:'var(--accent)'};
  return `<div class="stat-card"><div class="stat-label">${label}</div><div class="stat-value">${value}</div><div class="stat-sub">${sub}</div><div class="stat-accent" style="background:${cols[type]||cols.neutral}"></div></div>`;
}
function attRow(code,att,total,rate,status){
  const col=status==='good'?'green':status==='bad'?'red':'amber';
  return `<div style="display:flex;align-items:center;gap:10px;padding:8px 0;border-bottom:1px solid var(--border)">
    <span style="font-family:var(--mono);font-size:12px;color:var(--accent);width:72px;flex-shrink:0">${code}</span>
    <div style="flex:1"><div class="progress-bar"><div class="progress-fill ${col}" style="width:${rate}"></div></div></div>
    <span style="font-size:12px;font-family:var(--mono);width:40px;text-align:right">${rate}</span>
  </div>`;
}
function gradeRow(code,score,grade){
  const col=grade==='A'?'badge-green':grade==='B'?'badge-blue':grade==='C'?'badge-amber':'badge-red';
  return `<div style="display:flex;align-items:center;justify-content:space-between;padding:8px 0;border-bottom:1px solid var(--border);font-size:13px">
    <span style="font-family:var(--mono);font-size:12px;color:var(--accent)">${code}</span>
    <span class="font-medium">${score}/100</span>
    <span class="badge ${col}">${grade}</span>
  </div>`;
}
function miniNotif(icon,title,desc,time){
  return `<div style="display:flex;gap:10px;padding:10px 0;border-bottom:1px solid var(--border)">
    <span style="font-size:16px;flex-shrink:0;line-height:1.4">${icon}</span>
    <div style="flex:1"><div style="font-size:13px;font-weight:500">${title}</div><div style="font-size:12px;color:var(--text2)">${desc}</div></div>
    <span style="font-size:11px;color:var(--text3);flex-shrink:0;white-space:nowrap">${time}</span>
  </div>`;
}
function lecCourseRow(code,name,students,att){
  return `<div style="display:flex;align-items:center;gap:10px;padding:10px 0;border-bottom:1px solid var(--border)">
    <div style="width:8px;height:8px;border-radius:50%;background:var(--accent);flex-shrink:0"></div>
    <div style="flex:1"><div style="font-size:13px;font-weight:500">${code} — ${name}</div><div style="font-size:12px;color:var(--text2)">${students} · ${att}</div></div>
  </div>`;
}
function materialRow(icon,name,meta){
  return `<div style="display:flex;align-items:center;gap:10px;padding:8px 0;border-bottom:1px solid var(--border)">
    <span style="font-size:16px">${icon}</span>
    <div style="flex:1"><div style="font-size:13px;font-weight:500">${name}</div><div style="font-size:11px;color:var(--text3)">${meta}</div></div>
    <button class="btn btn-ghost btn-sm">${iconDown()}</button>
  </div>`;
}
function scoreRow(label,score,max,pct,note=''){
  return `<div style="display:flex;align-items:center;justify-content:space-between;padding:8px 0;border-bottom:1px solid var(--border);font-size:13px">
    <span class="text-muted">${label}</span>
    <div class="flex items-center gap-3">
      ${note?`<span class="text-xs text-faint">${note}</span>`:''}
      <span style="font-family:var(--mono)">${score}/${max}</span>
      <span class="font-medium" style="color:var(--accent)">${pct}</span>
    </div>
  </div>`;
}
function reportRow(key,val){
  return `<div style="display:flex;gap:8px;padding:7px 0;border-bottom:1px solid var(--border);font-size:13px"><span style="width:140px;flex-shrink:0;color:var(--text2)">${key}</span><span class="font-medium">${val}</span></div>`;
}
function transcriptSemester(label,gpa,units,courses){
  const gradeCols={A:'badge-green',B:'badge-blue',C:'badge-amber',D:'badge-red'};
  return `<div style="margin-bottom:14px">
    <div style="font-size:12px;font-weight:600;color:var(--text2);margin-bottom:6px;display:flex;justify-content:space-between">
      <span>${label}</span><span>GPA: ${gpa} · ${units} credits</span>
    </div>
    ${courses.map(c=>`<div style="display:flex;align-items:center;justify-content:space-between;padding:5px 0;border-bottom:1px solid var(--border);font-size:12px">
      <span style="font-family:var(--mono);color:var(--accent)">${c.code}</span>
      <span class="flex-1" style="margin:0 12px">${c.name}</span>
      <span>${c.units} units</span>
      <span class="badge ${gradeCols[c.grade]||'badge-gray'}" style="margin-left:8px">${c.grade}</span>
    </div>`).join('')}
  </div>`;
}
function healthRow(label,val,status){
  const col=status==='good'?'badge-green':status==='warn'?'badge-amber':'badge-red';
  return `<div style="display:flex;align-items:center;justify-content:space-between;padding:10px 0;border-bottom:1px solid var(--border);font-size:13px">
    <span class="text-muted">${label}</span><span class="badge ${col}">${val}</span>
  </div>`;
}
function deptRow(dept,stu,lec,courses,att,risk){
  return `<tr><td class="font-medium">${dept}</td><td>${stu}</td><td>${lec}</td><td>${courses}</td>
    <td><span class="badge badge-green">${att}</span></td><td><span class="badge badge-red">${risk}</span></td></tr>`;
}
function analyticsRow(dept,gpa,att,risk,pass,trend){
  const tc=trend==='↑'?'#15803d':trend==='↓'?'#b91c1c':'#6b6860';
  return `<tr><td class="font-medium">${dept}</td>
    <td><span style="font-family:var(--mono)">${gpa}</span></td>
    <td><span class="badge badge-green">${att}</span></td>
    <td><span class="badge badge-red">${risk}</span></td>
    <td><span class="badge badge-green">${pass}</span></td>
    <td><span style="font-size:16px;font-weight:600;color:${tc}">${trend}</span></td></tr>`;
}
function ttRow(course,lec,days,time,venue,students){
  return `<tr>
    <td><span style="font-family:var(--mono);font-size:12px;color:var(--accent)">${course}</span></td>
    <td>${lec}</td><td class="text-muted">${days}</td><td class="text-muted">${time}</td>
    <td class="text-muted">${venue}</td><td>${students}</td>
    <td><div class="flex gap-2"><button class="btn btn-ghost btn-sm">${iconEdit()} Edit</button><button class="btn btn-ghost btn-sm" style="color:#b91c1c">${iconTrash()}</button></div></td>
  </tr>`;
}
function reachRow(label,count,badge){
  return `<div style="display:flex;align-items:center;justify-content:space-between;padding:8px 0;border-bottom:1px solid var(--border);font-size:13px">
    <span class="text-muted">${label}</span><span class="badge ${badge}">${count}</span>
  </div>`;
}
function toggle(label,desc,checked){
  return `<div class="setting-row">
    <div><div class="setting-label">${label}</div><div class="setting-desc">${desc}</div></div>
    <label class="toggle-switch"><input type="checkbox" ${checked?'checked':''}><span class="toggle-slider"></span></label>
  </div>`;
}
function settingField(label,val){
  return `<div style="display:flex;gap:8px;padding:8px 0;border-bottom:1px solid var(--border);font-size:13px">
    <span style="width:160px;flex-shrink:0;color:var(--text2)">${label}</span><span class="font-medium">${val}</span>
  </div>`;
}
function iconBook(){return icon('<path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>')}
function iconUsers(){return icon('<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>')}
</script>
</body>
</html>
