];

function lecturerMarkAtt(){
  const rows=ATT_STUDENTS.map((s,i)=>`<tr>
    <td><span style="font-family:var(--mono);font-size:12px">${s.id}</span></td>
    <td class="font-medium">${s.name}</td>
    <td>
      <div class="att-toggle">
        <button class="att-btn ${s.status==='present'?'present':''}" id="p-${i}" onclick="setAtt(${i},'present')">Present</button>
        <button class="att-btn ${s.status==='absent'?'absent':''}" id="a-${i}" onclick="setAtt(${i},'absent')">Absent</button>
      </div>
    </td>
  </tr>`).join('');
  return `
  <div class="page-header">
    <div><div class="page-title">Mark Attendance</div><div class="page-subtitle">CSC 301 — Algorithms · Mon Mar 14, 2026 · 09:00 AM</div></div>
    <div class="flex gap-2">
      <button class="btn btn-outline" onclick="markAll('present')">Mark All Present</button>
      <button class="btn btn-primary" onclick="saveAtt()">Save Attendance</button>
    </div>
  </div>
  <div class="card" style="margin-bottom:16px">
    <div class="grid-3">
      <div><div class="text-xs text-faint" style="text-transform:uppercase;letter-spacing:.05em">Course</div><div class="font-medium" style="margin-top:2px">CSC 301 — Algorithms</div></div>
      <div><div class="text-xs text-faint" style="text-transform:uppercase;letter-spacing:.05em">Date</div><div class="font-medium" style="margin-top:2px">Monday, March 14, 2026</div></div>
      <div><div class="text-xs text-faint" style="text-transform:uppercase;letter-spacing:.05em">Enrolled</div><div class="font-medium" style="margin-top:2px">87 students</div></div>
    </div>
  </div>
  <div class="tbl-wrap">
    <table><thead><tr><th>Matric No.</th><th>Student Name</th><th>Attendance</th></tr></thead>
    <tbody id="att-tbody">${rows}</tbody></table>
  </div>
  <div class="flex gap-2" style="margin-top:16px">
    <button class="btn btn-primary" onclick="saveAtt()">Save Attendance</button>
    <button class="btn btn-outline">Cancel</button>
  </div>`;
}

function setAtt(i,status){
  ATT_STUDENTS[i].status=status;
  const p=document.getElementById(`p-${i}`);
  const a=document.getElementById(`a-${i}`);
  if(p){p.className='att-btn'+(status==='present'?' present':'');}
  if(a){a.className='att-btn'+(status==='absent'?' absent':'');}
}
function markAll(s){ATT_STUDENTS.forEach((_,i)=>setAtt(i,s));}
function saveAtt(){
  const el=document.getElementById('att-tbody');
  if(el) el.style.opacity='.5';
  setTimeout(()=>{if(el)el.style.opacity='1';alert('Attendance saved successfully!');},600);
}

