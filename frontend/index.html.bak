  const glabels=['A','B','C','D','E','F'];
  const gbars=glabels.map((g,i)=>`<div class="bar-col"><div class="bar-fill" style="height:${gdist[i]*2}px"></div><div class="bar-label">${g}</div></div>`).join('');
  return `
