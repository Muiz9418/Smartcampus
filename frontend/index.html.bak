function renderAdminPage(id){
  switch(id){
    case 'dashboard':   return adminDashboard();
    case 'analytics':   return adminAnalytics();
    case 'students':    return adminStudents();
    case 'lecturers':   return adminLecturers();
    case 'courses':     return adminCourses();
    case 'timetable':   return adminTimetable();
    case 'att-overview':return adminAttOverview();
    case 'grades-mgmt': return adminGrades();
    case 'broadcast':   return adminBroadcast();
    case 'settings':    return adminSettings();
    default: return '<p>Page not found</p>';
  }
}

