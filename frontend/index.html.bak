function renderLecturerPage(id){
  switch(id){
    case 'dashboard':    return lecturerDashboard();
    case 'notifications':return lecturerNotifications();
    case 'schedule':     return lecturerSchedule();
    case 'mark-att':     return lecturerMarkAtt();
    case 'att-reports':  return lecturerAttReports();
    case 'upload-grades':return lecturerUploadGrades();
    case 'profile':      return profileSettings();
    default: return '<p>Page not found</p>';
  }
}

